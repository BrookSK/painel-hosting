# storage — ignorar conteúdo, manter estrutura via .gitkeep
/storage/logs/*
!/storage/logs/.gitkeep
/storage/ssh-keys/*
!/storage/ssh-keys/.gitkeep
/storage/uploads/imagens/*
!/storage/uploads/imagens/.gitkeep
/storage/backups/*
!/storage/backups/.gitkeep
